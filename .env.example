# ─── Mediatwist Automation Engine ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Required fields are marked with (REQUIRED).

# ─── Facebook / Meta Graph API ────────────────────────────────────────────────
PAGE_ID=your_facebook_page_id                  # (REQUIRED) Facebook Page ID
ACCESS_TOKEN=your_page_access_token            # (REQUIRED) Long-lived Page access token
FB_APP_ID=your_fb_app_id                       # (For token exchange) Facebook App ID
FB_APP_SECRET=your_fb_app_secret               # (For token exchange) Facebook App Secret

# ─── Instagram ────────────────────────────────────────────────────────────────
IG_ACCOUNT_ID=your_ig_business_account_id      # Instagram Business Account ID

# ─── LinkedIn ─────────────────────────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=your_linkedin_token      # LinkedIn OAuth2 access token
LINKEDIN_ORG_ID=your_org_id                    # LinkedIn Organization ID (posts as org if set)

# ─── Cloudinary (video/image hosting) ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name          # (REQUIRED for video) Cloudinary cloud name
CLOUDINARY_API_KEY=your_api_key                # (REQUIRED for video) Cloudinary API key
CLOUDINARY_API_SECRET=your_api_secret          # (REQUIRED for video) Cloudinary API secret

# ─── Claude API (optional — enhances content quality) ─────────────────────────
ANTHROPIC_API_KEY=                             # Anthropic API key for Claude content enhancement
CLAUDE_MODEL=claude-sonnet-4-20250514                  # Model to use

# ─── Remotion ─────────────────────────────────────────────────────────────────
REMOTION_COMPOSITION=FeedPost                  # FeedPost | ReelsPost | BrandedCaption | DataDashboard | KineticType

# ─── Caption Variations (for renderVariations.js — legacy) ───────────────────
CAPTION_1=Stop boosting posts. Start building strategy.
CAPTION_2=Your content calendar should run itself. Here's how.
CAPTION_3=90% of businesses miss this one posting window.
HEADLINE_1=Mediatwist
HEADLINE_2=Mediatwist
HEADLINE_3=Mediatwist

# ─── Scheduler ────────────────────────────────────────────────────────────────
CRON_SCHEDULE=0 9 * * *                        # Cron expression (daily at 9 AM)
TZ=America/New_York                            # Timezone for cron

# ─── Flags ────────────────────────────────────────────────────────────────────
TEST_MODE=false                                # true = log posts without publishing
DEBUG=false                                    # true = verbose error stack traces
