# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Get these from https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Caption Variations ───────────────────────────────────────────────────────
# These are injected into the Remotion compositions as props at render time
CAPTION_1=Stop boosting posts. Start building strategy. 🚀
CAPTION_2=Your content calendar should run itself. Here's how.
CAPTION_3=90% of businesses miss this one posting window.

# Optional: override headline per variation
HEADLINE_1=Mediatwist
HEADLINE_2=Mediatwist
HEADLINE_3=Mediatwist

# ─── Output (auto-filled by renderVariations.js after render + upload) ─────────
# These are written to .env.post — don't edit manually
REMOTION_POST_1_VIDEO_URL=
REMOTION_POST_2_VIDEO_URL=
REMOTION_POST_3_VIDEO_URL=
