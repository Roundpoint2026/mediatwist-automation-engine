{
  "name": "mediatwist-automation-engine",
  "version": "2.0.0",
  "description": "AI-powered daily content engine: generate → render → upload → publish (Facebook, Instagram, LinkedIn)",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "engine": "node index.js",
    "engine:dry": "node index.js --dry-run",
    "engine:content": "node index.js --content-only",
    "engine:test": "node index.js --test-post",
    "engine:stats": "node index.js --stats",
    "schedule": "node index.js --schedule",
    "queue": "node index.js --queue 7",
    "token:check": "node publishers/tokenManager.js --check",
    "token:exchange": "node publishers/tokenManager.js --exchange --save",
    "token:page": "node publishers/tokenManager.js --page-token --save",
    "post": "node run.js",
    "legacy:engine": "node workflows/runDailyEngine.js",
    "studio": "npx remotion studio",
    "render:videos": "node scripts/renderVideos.js",
    "render:variations": "node scripts/renderVariations.js",
    "render:feed": "npx remotion render src/index.ts FeedPost outputs/feed-post.mp4 --codec h264",
    "render:reels": "npx remotion render src/index.ts ReelsPost outputs/reels-post.mp4 --codec h264",
    "render:caption": "npx remotion render src/index.ts BrandedCaption outputs/caption-post.mp4 --codec h264",
    "render:dashboard": "npx remotion render src/index.ts DataDashboard outputs/dashboard-post.mp4 --codec h264",
    "render:kinetic": "npx remotion render src/index.ts KineticType outputs/kinetic-post.mp4 --codec h264",
    "sync:backgrounds": "node scripts/syncCanvaBackgrounds.js",
    "sync:backgrounds:quick": "node scripts/syncCanvaBackgrounds.js --quick",
    "music:seed": "node music/seedLibrary.js",
    "music:check": "node music/seedLibrary.js --check",
    "music:refresh": "node -e \"require('./music/musicManager').refreshLibrary(); console.log('Library refreshed')\"",
    "music:trending": "node music/trendingAudio.js",
    "blog:heroes": "node ai/blogImageEngine.js",
    "blog:heroes:dry": "node ai/blogImageEngine.js --dry-run",
    "blog:heroes:help": "node ai/blogImageEngine.js --help",
    "blog:heroes:regen": "node scripts/regenerateBlogHeroes.js",
    "blog:heroes:regen:dry": "node scripts/regenerateBlogHeroes.js --dry-run",
    "canva:refresh": "node scripts/canvaTokenManager.js",
    "canva:refresh:force": "node scripts/canvaTokenManager.js --force",
    "canva:check": "node scripts/canvaTokenManager.js --check",
    "carousel": "node scripts/publishDocumentPost.js",
    "carousel:dry": "node scripts/publishDocumentPost.js --dry-run",
    "carousel:preview": "node scripts/publishDocumentPost.js --preview",
    "carousel:pdf": "python3 scripts/generateCarouselPDF.py --json",
    "carousel:canva": "node scripts/publishCanvaCarousel.js",
    "carousel:auto": "node scripts/generateAndPublishCarousel.js",
    "carousel:auto:dry": "node scripts/generateAndPublishCarousel.js --dry-run",
    "carousel:auto:preview": "node scripts/generateAndPublishCarousel.js --preview",
    "aimee:blog": "node scripts/publishAimeeBlogPost.js",
    "aimee:blog:dry": "node scripts/publishAimeeBlogPost.js --dry-run",
    "aimee:blog:preview": "node scripts/publishAimeeBlogPost.js --preview",
    "syndicate": "node scripts/syndicateBlogPost.js",
    "syndicate:dry": "node scripts/syndicateBlogPost.js --dry-run",
    "syndicate:preview": "node scripts/syndicateBlogPost.js --preview",
    "syndicate:devto": "node scripts/syndicateBlogPost.js --platforms devto",
    "syndicate:hashnode": "node scripts/syndicateBlogPost.js --platforms hashnode",
    "syndicate:medium": "node scripts/syndicateBlogPost.js --platforms medium",
    "syndicate:reddit": "node scripts/syndicateBlogPost.js --platforms reddit",
    "creative": "node scripts/generateCreativePost.js",
    "creative:publish": "node scripts/generateCreativePost.js --publish",
    "creative:dry": "node scripts/generateCreativePost.js --dry-run",
    "creative:batch": "node scripts/generateCreativePost.js --batch 7",
    "creative:batch:dry": "node scripts/generateCreativePost.js --batch 7 --dry-run",
    "creative:batch:queue": "node scripts/generateCreativePost.js --batch 7 --queue",
    "creative:image": "node scripts/generateCreativePost.js --image",
    "creative:status": "node scripts/generateCreativePost.js --status",
    "creative:help": "node scripts/generateCreativePost.js --help",
    "cartoon": "node scripts/generateCartoonVideo.js",
    "cartoon:dry": "node scripts/generateCartoonVideo.js --dry-run --no-opus",
    "cartoon:preview": "node scripts/generateCartoonVideo.js --preview",
    "cartoon:render": "node scripts/generateCartoonVideo.js --render-only --no-opus",
    "cartoon:opus": "node scripts/generateCartoonVideo.js --use-opus",
    "cartoon:opus:dry": "node scripts/generateCartoonVideo.js --dry-run --use-opus",
    "cartoon:square": "node scripts/generateCartoonVideo.js --format square --no-opus",
    "cartoon:reels": "node scripts/generateCartoonVideo.js --format reels --no-opus",
    "cartoon:noart": "node scripts/generateCartoonVideo.js --no-illustrations --no-opus"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.340",
    "@remotion/cli": "4.0.340",
    "@remotion/renderer": "4.0.340",
    "axios": "^1.7.2",
    "cloudinary": "^2.5.0",
    "dotenv": "^16.4.5",
    "nodemailer": "^6.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "4.0.340"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.5.4"
  },
  "remotion": {
    "entryPoint": "src/index.ts"
  }
}
